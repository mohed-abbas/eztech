generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  rider
  warehouse_manager
  admin
}

enum VehicleType {
  bicycle
  scooter
  car
}

// rider onboarding application state — admin (Wilson) approves/rejects
enum RiderApplicationStatus {
  pending
  approved
  rejected
}

enum RiderDocumentType {
  license
  insurance
}

enum RiderDocumentStatus {
  pending
  approved
  rejected
}

// full delivery lifecycle — frontend timeline maps onto these
enum OrderStatus {
  awaiting_payment // commerce order created but unpaid — NOT in the rider pool until the webhook flips it to pending_assignment (D-04)
  pending_assignment // created, no rider yet — appears in the rider "available" list
  rider_assigned // a rider accepted, on the way to the warehouse
  at_warehouse // rider arrived at the warehouse
  picked_up // parcel collected
  in_transit // en route to the customer
  delivered // completed — counts toward earnings
  cancelled
}

// commerce payment state — separate from the rider fulfillment OrderStatus (D-03)
enum PaymentStatus {
  awaiting_payment // order created, not yet paid — NOT rider-visible
  paid // payment confirmed via signed webhook — order enters the rider pool
  refunded // cancelled and fully refunded
  failed // payment attempt failed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  phone        String   @default("")
  passwordHash String
  role         Role     @default(customer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // rider-specific fields — null for non-riders
  vehicleType            VehicleType?
  licenseNumber          String?
  insuranceNumber        String?
  riderApplicationStatus RiderApplicationStatus @default(pending)
  riderOnline            Boolean                @default(false)

  // global email opt-out (N-06) — checked before non-essential Resend sends; essential mail
  // (password reset, order/payment confirmation, lifecycle, return reminder) always sends
  emailOptOut Boolean @default(false)

  // Stripe customer for off-session charges (late fees). Created lazily at first checkout so the
  // saved card can be charged later without the customer present (Module 9).
  stripeCustomerId String?

  refreshTokens       RefreshToken[]
  riderDocuments      RiderDocument[]
  assignedOrders      Order[]              @relation("RiderOrders")
  customerOrders      Order[]              @relation("CustomerOrders")
  declinedOrders      OrderDecline[]
  assignedReturns     Return[]             @relation("RiderReturns")
  customerReturns     Return[]             @relation("CustomerReturns")
  notifications       Notification[]
  addresses           Address[]
  managedWarehouses   Warehouse[]          @relation("ManagedWarehouses")
  stockAdjustments    StockAdjustment[]    @relation("StockAdjustments")
  passwordResetTokens PasswordResetToken[]
}

// a customer's saved delivery address — captured at registration, editable later
model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String
  street    String
  city      String
  zipCode   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// single-use, expiring password-reset token — mirrors RefreshToken's hashed-at-rest, single-use shape
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // sha256 of the raw token; raw is emailed, never stored
  expiresAt DateTime
  usedAt    DateTime? // single-use: set on first successful reset
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiderDocument {
  id         String              @id @default(uuid())
  riderId    String
  type       RiderDocumentType
  fileName   String
  mimeType   String
  sizeBytes  Int
  url        String // path served from the uploads directory
  status     RiderDocumentStatus @default(pending)
  uploadedAt DateTime            @default(now())
  rider      User                @relation(fields: [riderId], references: [id], onDelete: Cascade)

  // a rider keeps only one document per type — supersede via upsert, not deleteMany+create
  @@unique([riderId, type])
  @@index([riderId])
}

model Order {
  id                  String      @id @default(uuid())
  reference           String      @unique // human-friendly, e.g. EZ-7F3A2C
  status              OrderStatus @default(pending_assignment)
  customerId          String?
  riderId             String?
  pickupAddress       String
  pickupLat           Float?
  pickupLng           Float?
  dropoffAddress      String
  dropoffLat          Float?
  dropoffLng          Float?
  riderFee            Decimal     @default(0) @db.Decimal(10, 2) // amount paid to the rider on delivery
  // when a rider is offered the order, they have until this timestamp to accept; then it expires back to pending_assignment
  assignmentExpiresAt DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // ── commerce fields (Phase 4) — additive, nullable/defaulted so the migration is
  // non-destructive over existing rider rows; legacy rows backfilled paymentStatus=paid (A1)
  paymentStatus         PaymentStatus? // null for legacy rider-origin rows; awaiting_payment → paid on webhook (D-04)
  subtotal              Decimal?       @db.Decimal(10, 2) // sum of line totals, server-computed (D-06)
  deliveryFee           Decimal?       @db.Decimal(10, 2) // from server env config (D-07)
  total                 Decimal?       @db.Decimal(10, 2) // subtotal + deliveryFee
  warehouseId           String? // single fulfillment warehouse picked at create (D-11)
  stripePaymentIntentId String? // anchors the order to its Stripe PaymentIntent
  // computed at the `delivered` transition = deliveredAt + max(perItem rental duration); null when
  // every line is flat-priced (no rental clock) — drives return-reminder scheduling (N-05)
  rentalEndsAt          DateTime?

  // ── late-fee fields (Module 9) — additive/nullable. Saved card captured on the paid webhook so
  // an overdue rental can be auto-charged off_session; the *ChargedAt guard makes the charge idempotent.
  stripePaymentMethodId       String? // the card saved at checkout, reused for the off_session late charge
  lateFeeAmount               Decimal?  @db.Decimal(10, 2) // amount actually charged for going overdue
  lateFeeChargedAt            DateTime? // set once the off_session charge succeeds — guards against double-charge
  lateFeeStripePaymentIntentId String?  // the PaymentIntent id of the late-fee charge

  customer User?          @relation("CustomerOrders", fields: [customerId], references: [id])
  rider    User?          @relation("RiderOrders", fields: [riderId], references: [id])
  events   OrderEvent[]
  declines OrderDecline[]
  returns  Return[]       @relation("OrderReturns")
  items    OrderItem[]

  @@index([status])
  @@index([riderId])
}

// a full snapshot of a purchased line (D-05) — order history stays correct even if the
// product is later renamed or deleted (productId nullable, SetNull on product deletion)
model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String? // nullable FK — preserved if the product is later deleted
  name          String // snapshot of the product name at purchase time
  imageUrl      String  @default("")
  quantity      Int
  durationUnit  String // flat | hourly | daily | weekly
  durationValue Int
  unitPrice     Decimal @db.Decimal(10, 2) // server-computed unit price (D-06)
  lineTotal     Decimal @db.Decimal(10, 2) // unitPrice * quantity * durationValue

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// a service delivery zone — GeoJSON Polygon stored in a Json column (Pitfall 5), checked
// server-side with Turf point-in-polygon at checkout (D-13/D-14)
model Zone {
  id        String   @id @default(uuid())
  name      String
  geometry  Json // full GeoJSON Polygon { type:'Polygon', coordinates:[[[lng,lat],...]] }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// records a rider declining (or letting expire) an offered order so it is not re-offered to them
model OrderDecline {
  id        String   @id @default(uuid())
  orderId   String
  riderId   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rider     User     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([orderId, riderId])
}

enum ReturnStatus {
  scheduled // customer scheduled a return — appears in the rider "available returns" list
  accepted // a rider took the return pickup
  completed // parcel collected from the customer — counts toward earnings
  cancelled
}

// resultat de l'inspection entrepot d'un retour collecte
enum ReturnInspection {
  available // article ok, remis en stock
  damaged // article endommage, hors stock
}

// a scheduled return pickup (rider collects a parcel from the customer and brings it back)
model Return {
  id            String       @id @default(uuid())
  reference     String       @unique // human-friendly, e.g. RET-7F3A2C
  status        ReturnStatus @default(scheduled)
  orderId       String? // the original delivery this return relates to (optional)
  customerId    String?
  riderId       String?
  pickupAddress String // where the rider collects the parcel (the customer's address)
  pickupLat     Float?
  pickupLng     Float?
  scheduledFor  DateTime? // when the customer expects the pickup
  riderFee      Decimal      @default(0) @db.Decimal(10, 2)
  completedAt   DateTime?
  // inspection entrepot post-collecte
  inspectionResult ReturnInspection?
  inspectionNote   String?
  inspectedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  customer User?  @relation("CustomerReturns", fields: [customerId], references: [id])
  rider    User?  @relation("RiderReturns", fields: [riderId], references: [id])
  order    Order? @relation("OrderReturns", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([riderId])
  @@index([orderId])
}

enum NotificationType {
  new_order // a new delivery job is available
  return_scheduled // a return pickup has been scheduled
  earning_credited // a completed delivery/return credited the rider
  order_confirmed // payment succeeded — customer-facing order confirmation
  rider_assigned // a rider accepted the delivery
  order_picked_up // parcel collected from the warehouse
  order_delivered // delivery completed
  return_reminder // scheduled reminder to return a rented item
  low_stock // admin alert — warehouse stock crossed the low-stock threshold
  return_processed // customer-facing — a returned item was inspected (restocked or damaged)
  late_fee_pending // customer-facing — rental is overdue, a late fee is about to be charged
  late_fee_charged // customer-facing — the late fee was charged to the saved card
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  // idempotency discriminators (Pitfall 3) — event/channel drive @@unique below; defaulted so
  // existing notify()/notifyOnlineRiders() call sites keep compiling and existing rows backfill cleanly
  event       String           @default("")
  channel     String           @default("in_app")
  orderId     String? // null for fan-out rows (rider alerts, low-stock) so they never collide (Pitfall 2)
  title       String
  body        String           @default("")
  read        Boolean          @default(false)
  readAt      DateTime?
  scheduledAt DateTime? // future send (e.g. return reminder)
  sentAt      DateTime? // cron claim guard — set in the same txn as the claim (Pitfall 4)
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderId, event, channel])
  @@index([userId, read])
  @@index([event, sentAt])
}

// ── Catalog ─────────────────────────────────────────────────────────────────
// Phase 3 (read-only catalog) draft. Mirrors the frontend mock (app/data/mock/
// products.json, categories.json, warehouses.json) so it can be seeded 1:1 and
// the catalog pages flip to VITE_USE_MOCK=false. Designed to be extended
// additively — Wilson can refine field shapes without a destructive migration.

// consumables/accessories rent for one flat price; devices rent on hourly/daily/weekly tiers
enum PricingType {
  flat
  tiered
}

// product taxonomy — mirrors categories.json (Chargeurs, Câbles, Ordinateurs, …)
model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String    @default("")
  icon        String    @default("") // iconify name used by the frontend, e.g. "ph:battery-charging"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// optional brand dimension for filtering (Apple, Samsung, Lenovo, …) — products may be unbranded/universal
model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

// a rentable catalog item — products.json maps 1:1 onto this
model Product {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String  @default("")
  categoryId  String
  brandId     String?
  imageUrl    String  @default("")

  pricingType PricingType @default(flat)
  // only the columns matching pricingType are populated: flat → flatPrice; tiered → hourly/daily/weekly
  flatPrice   Decimal?    @db.Decimal(10, 2)
  hourlyPrice Decimal?    @db.Decimal(10, 2)
  dailyPrice  Decimal?    @db.Decimal(10, 2)
  weeklyPrice Decimal?    @db.Decimal(10, 2)
  // single comparable price for catalog sorting across both pricing types (coalesced from the above)
  sortPrice   Decimal     @default(0) @db.Decimal(10, 2)

  compatibilityTags String[] // free-form tags powering "compatible with" search, e.g. ["Apple","USB-C"]
  stock             Int      @default(0) // denormalized total available; per-warehouse breakdown lives in WarehouseStock
  featured          Boolean  @default(false)
  rating            Decimal? @db.Decimal(2, 1)
  reviewCount       Int      @default(0)
  isActive          Boolean  @default(true) // admins soft-disable instead of deleting
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category         Category          @relation(fields: [categoryId], references: [id])
  brand            Brand?            @relation(fields: [brandId], references: [id])
  stocks           WarehouseStock[]
  orderItems       OrderItem[]
  stockAdjustments StockAdjustment[]

  @@index([categoryId])
  @@index([brandId])
  @@index([isActive, featured])
  @@index([isActive, sortPrice])
}

// a pickup/dispatch warehouse — mirrors warehouses.json
model Warehouse {
  id            String   @id @default(uuid())
  name          String
  address       String
  lat           Float
  lng           Float
  serviceRadius Int      @default(5) // km
  openTime      String   @default("08:00")
  closeTime     String   @default("22:00")
  isActive      Boolean  @default(true)
  managerId     String? // a warehouse_manager user, assigned by an admin
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  manager     User?             @relation("ManagedWarehouses", fields: [managerId], references: [id], onDelete: SetNull)
  stocks      WarehouseStock[]
  adjustments StockAdjustment[]

  @@index([managerId])
}

// per-warehouse stock of a product — replaces the mock's warehouseIds[] and seeds Phase 4 inventory
model WarehouseStock {
  id          String   @id @default(uuid())
  warehouseId String
  productId   String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
}

// journal des ajustements de stock (qui / quand / delta) — audit + demo
model StockAdjustment {
  id          String   @id @default(uuid())
  warehouseId String
  productId   String
  actorId     String // utilisateur ayant fait l'ajustement
  delta       Int // variation appliquee (+/-)
  reason      String?
  createdAt   DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  actor     User      @relation("StockAdjustments", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([warehouseId])
  @@index([productId])
}
