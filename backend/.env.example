NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:<your-local-db-password>@localhost:5432/eztech_dev
# MongoDB — ephemeral rider GPS positions (Phase 5). Dev-only localhost URI, no credentials.
MONGODB_URI=mongodb://localhost:27017/eztech_dev
# Required — generate a strong value:  openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LOG_LEVEL=info
ADMIN_EMAIL=admin@eztech.fr
ADMIN_PASSWORD=change-me
# Stripe (test mode keys from Stripe Dashboard -> Developers -> API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_PUBLISHABLE_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
# delivery fee single source of truth (D-07)
DELIVERY_FEE=4.99

# Optional — error tracking (GlitchTip/Sentry). Leave empty to disable (default).
# For the docker demo, set this to the DSN GlitchTip gives you, using the internal host:
#   http://<key>@glitchtip:8080/<project-id>
SENTRY_DSN=
