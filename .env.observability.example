# Telemetry / observability config — copy what you need into `eztech/.env` for the demo.
# `docker compose` auto-loads `eztech/.env`. Everything here is OPTIONAL: with these unset, the app
# runs normally and sends no telemetry. The observability backends only run when you add the overlay:
#
#   docker compose -f docker-compose.yml -f docker-compose.observability.yml up
#
# ----------------------------------------------------------------------------------------------------
# 1) Secrets for the self-hosted telemetry backends (used by docker-compose.observability.yml).
#    Safe dev defaults are baked in; override here for anything non-throwaway.
#    Generate real values with: openssl rand -hex 32
GLITCHTIP_SECRET_KEY=dev-only-change-me-please-0123456789
UMAMI_APP_SECRET=dev-only-change-me-umami

#    Host ports for the dashboards. Override if 8000 / 3002 are already taken on your machine.
GLITCHTIP_PORT=8000
UMAMI_PORT=3002

# ----------------------------------------------------------------------------------------------------
# 2) App-side wiring — fill these AFTER the backends are up and you've created a project / website.
#
#    GlitchTip (http://localhost:8000): create an account → organization → project, then copy its DSN.
#    The browser uses the host port; the Nuxt server + Express backend use the internal compose host.
NUXT_PUBLIC_SENTRY_DSN=
NUXT_SENTRY_DSN=
SENTRY_DSN=

#    Umami (http://localhost:3002, default login admin / umami): add a website, copy its id.
NUXT_PUBLIC_UMAMI_HOST=http://localhost:3002
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
