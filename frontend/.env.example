# Mock mode — set to "true" to use local JSON data instead of API
VITE_USE_MOCK=true

# API base URL (used when VITE_USE_MOCK=false)
VITE_API_URL=http://localhost:3001/api

# Socket.io endpoint — the realtime tracking client connects to the backend ROOT
# (not /api). Keep this in sync with the backend host/port.
VITE_SOCKET_URL=http://localhost:3001

# Stripe publishable key (pk_test_... for the test stack) — public, used by Stripe Elements
VITE_STRIPE_PUBLISHABLE_KEY=

# Delivery fee surfaced to the cart via the BFF (server-side single source of truth)
NUXT_DELIVERY_FEE=4.99

# --- Telemetry (all optional — leave empty to disable, which is the default) ---
# Error tracking (GlitchTip/Sentry). Browser DSN uses the host port; the Nuxt server DSN
# uses the internal compose host. For the docker demo, get these from GlitchTip after
# creating a project (Settings → Projects → DSN):
#   NUXT_PUBLIC_SENTRY_DSN=http://<key>@localhost:8000/<project-id>
#   NUXT_SENTRY_DSN=http://<key>@glitchtip:8080/<project-id>
NUXT_PUBLIC_SENTRY_DSN=
NUXT_SENTRY_DSN=

# Web analytics (Umami). Get the website id from the Umami UI after adding a website:
#   NUXT_PUBLIC_UMAMI_HOST=http://localhost:3002
#   NUXT_PUBLIC_UMAMI_WEBSITE_ID=<uuid from Umami>
NUXT_PUBLIC_UMAMI_HOST=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
