# EzTech — Docker Compose env template. Copy to `.env` and adjust:  cp .env.example .env
# This is the single global file `docker compose` auto-loads (for the dev stack + telemetry overlay).
# It is NOT used when running apps natively — those read backend/.env and frontend/.env.

# ─── App: Postgres ──────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eztech_dev

# ─── App: Backend ───────────────────────────────────────────────────────────────────────────
# Required — generate a strong value:  openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@eztech.fr
ADMIN_PASSWORD=change-me
SEED_CATALOG=true
SEED_DEMO=true

# ─── App: Frontend ──────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_USE_MOCK=false

# ─── Telemetry: self-hosted backends (only used by docker-compose.observability.yml) ─────────
# Required app secrets — generate strong values with: openssl rand -hex 32
GLITCHTIP_SECRET_KEY=
UMAMI_APP_SECRET=
# Internal-only telemetry DB passwords (the GlitchTip/Umami Postgres containers expose no host port).
GLITCHTIP_DB_PASSWORD=glitchtip
UMAMI_DB_PASSWORD=umami
# Dashboard host ports — change if 8000 / 3002 are already taken on your machine.
GLITCHTIP_PORT=8000
UMAMI_PORT=3002

# ─── Telemetry: app wiring — FILL IN after the dashboards are up and you've created a project/site ──
# GlitchTip (http://localhost:8000) → org → project → copy the DSN.
#   browser DSN uses the host port; the Nuxt server + backend use the internal compose host (glitchtip:8080)
#   e.g. NUXT_PUBLIC_SENTRY_DSN=http://<key>@localhost:8000/<project-id>
#        NUXT_SENTRY_DSN=http://<key>@glitchtip:8080/<project-id>   (same for SENTRY_DSN)
NUXT_PUBLIC_SENTRY_DSN=
NUXT_SENTRY_DSN=
SENTRY_DSN=
# Umami (http://localhost:3002, login admin / umami) → add a website → copy its id.
NUXT_PUBLIC_UMAMI_HOST=http://localhost:3002
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
